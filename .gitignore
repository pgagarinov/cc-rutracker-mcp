# ---- Rust ----
/target
**/*.rs.bk
*.pdb

# Benchmark / Criterion output
/target/criterion/

# ---- Coverage (US-008) ----
/lcov.info
/coverage-report/

# ---- Project-specific ----

# Cached cookies (contains session tokens)
.cookies.json

# Categories cache (forum directory)
.categories.json

# Release-gate soak logs
soak-*.log

# ---- Agent / tooling state (user-local, not for the repo) ----
# .claude/ is mostly user-local (settings, hooks, session state), BUT we DO
# version the project-scoped agents and skills — they are code artefacts that
# the ranker + scan pipeline depend on at runtime.
.claude/
!.claude/agents/
!.claude/agents/**
!.claude/skills/
!.claude/skills/**
.omc/artifacts/
.omc/sessions/
.omc/state/
.omc/project-memory.json
.omx/

# ---- Editor / IDE ----
/.idea/
/.vscode/
*.iml
.fleet/

# ---- Vim / Emacs swap ----
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Env / secrets (belt & braces — this project has none, but keep anyway) ----
.env
.env.*
!.env.example
